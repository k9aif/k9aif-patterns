@startuml critic-actor-pattern
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam ArrowColor #444444
skinparam SequenceArrowColor #1C69D4
skinparam SequenceBoxBackgroundColor #f7f4ef

title Critic-Actor Pattern — Execution Flow

participant "Orchestrator" as O #e8f0fb
participant "BaseCriticActorAgent\n(Actor)" as A #e8f0fb
participant "Critic\n(LLM / Validator)" as C #fef3e8
participant "Context / Output" as CTX #f4faf4

O -> A : execute(payload)
activate A

A -> A : generate(payload)
note right: Actor produces first draft

A -> CTX : draft_output

loop until should_accept() or max_rounds reached

  A -> C : critique(draft_output)
  activate C
  C --> A : CritiqueResult\n{ accepted, feedback, score }
  deactivate C

  alt accepted == True
    A -> A : finalize(draft_output)
    A --> O : CriticActorResult\n{ output, accepted, rounds }
  else accepted == False
    A -> A : refine(draft_output, feedback)
    note right: Actor revises based on critique
    A -> CTX : refined_output
  end

end

alt max_rounds exceeded and not accepted
  A -> A : escalate()
  A --> O : CriticActorResult\n{ disposition: ESCALATE }
end

deactivate A

@enduml
