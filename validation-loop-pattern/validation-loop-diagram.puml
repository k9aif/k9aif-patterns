@startuml validation-loop-pattern
!theme plain
skinparam backgroundColor #FAFAFA
skinparam defaultFontName Arial
skinparam ArrowColor #444444
skinparam SequenceArrowColor #1C69D4

title Validation Loop Pattern — Execution Flow

participant "Orchestrator" as O #e8f0fb
participant "BaseValidationLoopAgent" as A #e8f0fb
participant "Validation Tool\n(LLM / Rule Engine / API)" as T #fef3e8
participant "ValidationLoopContext" as CTX #f4faf4

O -> A : execute(payload)
activate A

A -> CTX : initialise(payload, iteration=0)

loop while CONTINUE

  A -> A : generate_hypothesis(loop_ctx)
  note right: Form next hypothesis\nbased on prior steps

  A -> T : run_validation(hypothesis, loop_ctx)
  activate T
  T --> A : tool_result (raw)
  deactivate T

  A -> A : evaluate_observation(tool_result, loop_ctx)
  note right: Returns { confidence, ... }

  A -> CTX : record ValidationLoopStep

  A -> A : should_continue(observation, loop_ctx)
  note right: Returns disposition

  alt FINALIZE
    A -> A : finalize(loop_ctx)
    A --> O : ValidationLoopResult\n{ output, confidence, iterations }
  else ESCALATE
    A -> A : escalate(loop_ctx)
    A --> O : ValidationLoopResult\n{ disposition: ESCALATE }
  else FAIL
    A -> A : fail(loop_ctx)
    A --> O : ValidationLoopResult\n{ disposition: FAIL }
  else CONTINUE
    A -> CTX : iteration += 1
  end

end

deactivate A

@enduml
